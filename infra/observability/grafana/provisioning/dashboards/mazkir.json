{
  "title": "Mazkir",
  "uid": "mazkir-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Agent turns",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"vault-server\", event_type=\"agent_iter\"} | json"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Tool calls",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"vault-server\", event_type=\"tool_call\"} | json"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Errors",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{level=\"ERROR\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Bot inbound",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"telegram-bot\", event_type=\"update_received\"} | json"
        }
      ]
    }
  ]
}
