# Telegram Configuration
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890  # Not used in bot mode, kept for compatibility
TELEGRAM_SESSION_NAME=mazkir_session
TELEGRAM_BOT_TOKEN=your_bot_token_here  # REQUIRED - Get from @BotFather

# Database Configuration
DATABASE_URL=postgresql+asyncpg://mazkir:mazkir_dev_password@localhost:5432/mazkir

# Claude API (required for v2.0)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4000

# Ollama Configuration (optional, kept for flexibility)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vault Configuration
VAULT_PATH=/home/marcellmc/pkm
VAULT_TIMEZONE=Asia/Jerusalem

# Google Calendar Integration
# To enable: Set ENABLE_CALENDAR_SYNC=true and provide OAuth2 credentials
# 1. Go to Google Cloud Console -> Enable Calendar API
# 2. Create OAuth2 credentials (Desktop app)
# 3. Download JSON and save as google_credentials.json
ENABLE_CALENDAR_SYNC=false
GOOGLE_CREDENTIALS_PATH=google_credentials.json
GOOGLE_TOKEN_PATH=~/.config/mazkir/google_token.json
# GOOGLE_CALENDAR_ID=  # Optional: cached Mazkir calendar ID (auto-detected)
DEFAULT_HABIT_TIME=07:00
DEFAULT_EVENT_DURATION=30

# Features
ENABLE_WEBAPP=true
ENABLE_NOTIFICATIONS=true
DEBUG=false

# Security
AUTHORIZED_USER_ID=your_telegram_user_id_here

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
